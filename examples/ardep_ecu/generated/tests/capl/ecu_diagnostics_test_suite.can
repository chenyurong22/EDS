testcase TC_DID_Read_Smoke_F190()
{
  int   rc;
  char  stepName[64];
  TestCaseDescription("Smoke: ReadDataByIdentifier 0xF190 (VehicleIdentificationNumber) — happy path");

  Uds_EnterSession(kSessDefault);

  rc = Uds_ReadDid(0xF1, 0x90);

  snprintf(stepName, elcount(stepName), "RDBI_0xF190_PositiveResponse");
  AssertPositiveResponse(rc, kSidRDBI, stepName);

  /* Response: 0x62 DID_HI DID_LO + 17 data bytes = 20 total */
  snprintf(stepName, elcount(stepName), "RDBI_0xF190_ResponseLength");
  AssertResponseLength(gRxLen, 20, stepName);

  Uds_EnterSession(kSessDefault);
}
