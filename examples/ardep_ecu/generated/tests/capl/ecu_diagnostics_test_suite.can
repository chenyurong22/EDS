variables
{
  /* ── CAN / ISO-TP addressing ───────────────────────────────────────────── */
  const dword kRxCanId          = 0x7DF;   /* Tester → ECU */
  const dword kTxCanId          = 0x7E8;   /* ECU → Tester */
  const int   kExtendedAddrMode = 0;                /* 11-bit CAN IDs */

  /* ── Timing (milliseconds) ────────────────────────────────────────────── */
  const dword kP2ServerMax      = 25;
  const dword kP2StarServerMax  = 5000;
  const dword kS3ServerTimeout  = 5000;
  const dword kIsoTpTimeout     = 6000;

  /* ── UDS Service IDs ──────────────────────────────────────────────────── */
  const byte  kSidDSC           = 0x10;  /* DiagnosticSessionControl */
  const byte  kSidECUReset      = 0x11;  /* ECUReset */
  const byte  kSidRDTCI         = 0x19;  /* ReadDTCInformation */
  const byte  kSidRDBI          = 0x22;  /* ReadDataByIdentifier */
  const byte  kSidSA            = 0x27;  /* SecurityAccess */
  const byte  kSidWDBI          = 0x2E;  /* WriteDataByIdentifier */
  const byte  kSidTesterPresent = 0x3E;  /* TesterPresent */
  const byte  kSidNR            = 0x7F;  /* NegativeResponse */
  const byte  kPosDelta         = 0x40;  /* Positive response SID offset */

  /* ── UDS Session sub-functions ────────────────────────────────────────── */
  const byte  kSessDefault      = 0x01;
  const byte  kSessProgramming  = 0x02;
  const byte  kSessExtended     = 0x03;

  /* ── UDS Negative Response Codes ──────────────────────────────────────── */
  const byte  kNrcGenReject          = 0x10;
  const byte  kNrcSvcNotSupported    = 0x11;
  const byte  kNrcIncorrectMsgLen    = 0x13;
  const byte  kNrcResponsePending    = 0x78;
  const byte  kNrcConditionsNotMet   = 0x22;
  const byte  kNrcReqOutOfRange      = 0x31;
  const byte  kNrcSecAccessDenied    = 0x33;
  const byte  kNrcInvalidKey         = 0x35;
  const byte  kNrcExceedAttempts     = 0x36;
  const byte  kNrcTimeDelayNotExp    = 0x37;
  const byte  kNrcSvcNotSuppInSess   = 0x7F;

  /* ── Security key placeholders (override before production use) ─────────
   *   Format: kSecKeyLevelN[16] = 16-byte AES-128 secret key for level N
   *   These are the default EDS dev keys — replace for production ECUs.     */
  byte  kSecKeyLevel1[16] = { 0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
                               0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F };

  /* ── ISO-TP frame buffers ─────────────────────────────────────────────── */
  byte  gTxBuf[4095];
  byte  gRxBuf[4095];
  dword gTxLen;
  dword gRxLen;
  int   gLastNrc;

  /* ── Test state ───────────────────────────────────────────────────────── */
  int   gCurrentSession;       /* 1=default 2=programming 3=extended */
  int   gSecurityLevel;        /* 0=locked, N=level-N unlocked */
  dword gTestPassCount;
  dword gTestFailCount;

  /* ── ISO-TP message objects ───────────────────────────────────────────── */
  message 0x000 gCanTxMsg;
  message 0x000 gCanRxMsg;
}


/* ═══════════════════════════════════════════════════════════════════════════
 *  ISO-TP TRANSPORT LAYER
 *  Minimal single-frame / multi-frame send+receive for UDS payloads ≤ 4095 B
 * ═══════════════════════════════════════════════════════════════════════════ */

/*
 * IsoTp_Send — assemble and transmit an ISO-TP frame sequence for a UDS PDU.
 * Parameters:
 *   pdu[]  : UDS payload bytes
 *   pduLen : number of valid bytes in pdu[]
 * Returns 0 on success, -1 on error.
 */
int IsoTp_Send(byte pdu[], dword pduLen)
{
  byte  frame[8];
  dword remaining;
  dword offset;
  byte  sn;     /* consecutive frame sequence number */
  dword i;

  if (pduLen == 0 || pduLen > 4095) {
    TestStepFail("IsoTp_Send", "Invalid PDU length");
    return -1;
  }

  if (pduLen <= 7) {
    /* ── Single Frame ─────────────────────────────────────────────────── */
    frame[0] = (byte)(pduLen & 0x0F);   /* PCItype=0, DL=pduLen */
    for (i = 0; i < pduLen; i++) {
      frame[i + 1] = pdu[i];
    }
    /* Pad to 8 bytes with 0xCC */
    for (i = pduLen + 1; i < 8; i++) {
      frame[i] = 0xCC;
    }
  } else {
    /* ── First Frame ──────────────────────────────────────────────────── */
    frame[0] = (byte)(0x10 | ((pduLen >> 8) & 0x0F));
    frame[1] = (byte)(pduLen & 0xFF);
    for (i = 0; i < 6; i++) {
      frame[i + 2] = pdu[i];
    }
  }

  /* Transmit first frame (or single frame) */
  gCanTxMsg.id  = kRxCanId;
  gCanTxMsg.dlc = 8;
  for (i = 0; i < 8; i++) {
    gCanTxMsg.byte(i) = frame[i];
  }
  output(gCanTxMsg);

  if (pduLen <= 7) {
    return 0;   /* Single Frame — done */
  }

  /* ── Wait for Flow Control ────────────────────────────────────────────── */
  /* (handled in IsoTp_Receive — we block on the FC before sending CF) */
  remaining = pduLen - 6;
  offset    = 6;
  sn        = 1;

  while (remaining > 0) {
    dword chunkLen;
    chunkLen = (remaining > 7) ? 7 : remaining;
    frame[0] = (byte)(0x20 | (sn & 0x0F));   /* Consecutive Frame */
    for (i = 0; i < chunkLen; i++) {
      frame[i + 1] = pdu[offset + i];
    }
    for (i = chunkLen + 1; i < 8; i++) {
      frame[i] = 0xCC;
    }
    for (i = 0; i < 8; i++) {
      gCanTxMsg.byte(i) = frame[i];
    }
    output(gCanTxMsg);

    offset    += chunkLen;
    remaining -= chunkLen;
    sn         = (sn + 1) & 0x0F;
  }

  return 0;
}

/*
 * IsoTp_Receive — blocking receive of an ISO-TP frame sequence.
 * Fills gRxBuf and sets gRxLen.
 * Returns 0 on success, -1 on timeout/error.
 */
int IsoTp_Receive()
{
  /* Implementation via CANoe message-event polling.
   * Real implementation uses on message handler below.
   * This stub returns -1; on message 0x... handler populates gRxBuf. */
  dword timeout_ms;
  timeout_ms = kIsoTpTimeout;
  gRxLen = 0;

  /* waitForMessage is done via on message handler + testWaitForEvent */
  return 0;
}

/*
 * UdsRequest — send a UDS PDU and wait for the response.
 * Returns byte count in gRxBuf, or -1 on timeout.
 */
int UdsRequest(byte pdu[], dword pduLen)
{
  int rc;
  gRxLen    = 0;
  gLastNrc  = 0;

  rc = IsoTp_Send(pdu, pduLen);
  if (rc < 0) return -1;

  /* Wait up to P2*server_max + margin for response */
  if (testWaitForEvent("eds_isotp_rx_complete", kIsoTpTimeout) == 0) {
    /* timeout */
    return -1;
  }

  /* Check for pending response (NRC 0x78) — loop up to 5 times */
  if (gRxLen >= 3 && gRxBuf[0] == kSidNR && gRxBuf[2] == kNrcResponsePending) {
    int retries;
    for (retries = 0; retries < 5; retries++) {
      if (testWaitForEvent("eds_isotp_rx_complete", kP2StarServerMax + 500) != 0) {
        if (!(gRxLen >= 3 && gRxBuf[0] == kSidNR && gRxBuf[2] == kNrcResponsePending)) {
          break;
        }
      } else {
        return -1;   /* Final timeout waiting for 0x78 chain */
      }
    }
  }

  if (gRxLen >= 3 && gRxBuf[0] == kSidNR) {
    gLastNrc = gRxBuf[2];
  }

  return (int)gRxLen;
}

/* ── ISO-TP receive event handler ────────────────────────────────────────── */
on message kTxCanId
{
  byte  pciType;
  dword dataLen;
  dword i;
  static byte  sfBuf[4095];
  static dword sfExpected;
  static dword sfReceived;
  static byte  sfNextSn;

  pciType = (this.byte(0) & 0xF0) >> 4;

  switch (pciType) {
    case 0x0:   /* Single Frame */
      dataLen = this.byte(0) & 0x0F;
      if (dataLen == 0 || dataLen > 7) break;
      for (i = 0; i < dataLen; i++) {
        gRxBuf[i] = this.byte(i + 1);
      }
      gRxLen = dataLen;
      testSetEvent("eds_isotp_rx_complete");
      break;

    case 0x1:   /* First Frame */
      sfExpected = ((dword)(this.byte(0) & 0x0F) << 8) | this.byte(1);
      sfReceived = 6;
      sfNextSn   = 1;
      for (i = 0; i < 6; i++) {
        sfBuf[i] = this.byte(i + 2);
      }
      /* Send Flow Control: ContinueToSend, BS=0, STmin=0 */
      {
        message kRxCanId fcMsg;
        fcMsg.dlc = 8;
        fcMsg.byte(0) = 0x30;   /* FC, FS=0 (CTS) */
        fcMsg.byte(1) = 0x00;   /* BlockSize=0 (send all) */
        fcMsg.byte(2) = 0x00;   /* STmin=0 ms */
        for (i = 3; i < 8; i++) fcMsg.byte(i) = 0xCC;
        output(fcMsg);
      }
      break;

    case 0x2:   /* Consecutive Frame */
      {
        byte  rxSn;
        dword chunkLen;
        rxSn = this.byte(0) & 0x0F;
        if (rxSn != sfNextSn) {
          TestStepFail("IsoTp_RX", "Sequence number mismatch");
          break;
        }
        chunkLen = (sfExpected - sfReceived > 7) ? 7 : (sfExpected - sfReceived);
        for (i = 0; i < chunkLen; i++) {
          sfBuf[sfReceived + i] = this.byte(i + 1);
        }
        sfReceived += chunkLen;
        sfNextSn    = (sfNextSn + 1) & 0x0F;
        if (sfReceived >= sfExpected) {
          for (i = 0; i < sfExpected; i++) {
            gRxBuf[i] = sfBuf[i];
          }
          gRxLen = sfExpected;
          testSetEvent("eds_isotp_rx_complete");
        }
      }
      break;

    default:
      break;
  }
}


/* ═══════════════════════════════════════════════════════════════════════════
 *  UDS HELPER PROCEDURES
 * ═══════════════════════════════════════════════════════════════════════════ */

/*
 * Uds_EnterSession — switch to a UDS diagnostic session.
 * sessionByte: 0x01=default, 0x02=programming, 0x03=extended
 * Returns 1 on success, 0 on failure.
 */
int Uds_EnterSession(byte sessionByte)
{
  byte  pdu[2];
  int   rc;

  pdu[0] = kSidDSC;
  pdu[1] = sessionByte;

  rc = UdsRequest(pdu, 2);
  if (rc < 0) {
    TestStepFail("EnterSession", "No response");
    return 0;
  }
  if (gRxBuf[0] != (byte)(kSidDSC + kPosDelta)) {
    TestStepFail("EnterSession",
      "Negative response 0x%02X NRC=0x%02X", gRxBuf[1], gRxBuf[2]);
    return 0;
  }
  gCurrentSession = (int)sessionByte;
  return 1;
}

/*
 * Uds_TesterPresent — send TesterPresent (0x3E 0x00) keep-alive.
 */
void Uds_TesterPresent()
{
  byte pdu[2];
  pdu[0] = kSidTesterPresent;
  pdu[1] = 0x00;
  UdsRequest(pdu, 2);
}

/*
 * Uds_SecurityAccessRequestSeed — send RequestSeed for given level.
 * Seed bytes are stored in gRxBuf[2..].
 * Returns seed length (bytes) or -1 on failure.
 */
int Uds_SecurityAccessRequestSeed(int level)
{
  byte  pdu[2];
  int   rc;
  byte  seedSub;

  seedSub  = (byte)((level * 2) - 1);
  pdu[0]   = kSidSA;
  pdu[1]   = seedSub;

  rc = UdsRequest(pdu, 2);
  if (rc < 2) {
    TestStepFail("RequestSeed", "No response for level %d", level);
    return -1;
  }
  if (gRxBuf[0] != (byte)(kSidSA + kPosDelta)) {
    TestStepFail("RequestSeed",
      "NRC=0x%02X for level %d", gRxBuf[2], level);
    return -1;
  }
  return rc - 2;   /* seed bytes start at gRxBuf[2] */
}

/*
 * Uds_SecurityAccessSendKey — send computed key for given level.
 * key[]: 4-byte derived key
 * Returns 1 on success, 0 on failure.
 */
int Uds_SecurityAccessSendKey(int level, byte key[], dword keyLen)
{
  byte  pdu[6];
  int   rc;
  byte  keySub;
  dword i;

  keySub = (byte)(level * 2);
  pdu[0] = kSidSA;
  pdu[1] = keySub;
  for (i = 0; i < keyLen && i < 4; i++) {
    pdu[2 + i] = key[i];
  }

  rc = UdsRequest(pdu, 2 + keyLen);
  if (rc < 0 || gRxBuf[0] != (byte)(kSidSA + kPosDelta)) {
    TestStepFail("SendKey", "Key rejected for level %d NRC=0x%02X",
      level, (rc < 0) ? 0xFF : gRxBuf[2]);
    return 0;
  }
  gSecurityLevel = level;
  return 1;
}

/*
 * Uds_UnlockLevel — perform complete seed/key exchange for one security level.
 * Uses the kSecKeyLevelN arrays defined in variables block.
 * Returns 1 on success, 0 on failure.
 *
 * Key derivation: EDS uses AES-128-CMAC truncated to 4 bytes.
 * CAPL does not have native AES — provide the pre-computed key or
 * implement XOR stub for development:  key = seed XOR kSecKeyLevel[0..3]
 */
int Uds_UnlockLevel(int level)
{
  byte  seed[32];
  byte  key[4];
  int   seedLen;
  dword i;

  seedLen = Uds_SecurityAccessRequestSeed(level);
  if (seedLen < 0) return 0;

  /* Copy seed from response buffer */
  for (i = 0; i < (dword)seedLen && i < 32; i++) {
    seed[i] = gRxBuf[2 + i];
  }

  /*
   * KEY DERIVATION — replace this with your AES-128-CMAC implementation.
   *
   * Production EDS firmware uses:
   *   key[0..3] = AES-128-CMAC(kSecKeyLevelN, seed)[0..3]
   *
   * Development XOR stub (matches testgen.py xor_stub mode):
   *   key[i] = seed[i] ^ kSecKeyLevel1[i]   for i = 0..3
   *
   * To use AES in CANoe: implement via CAPL DLL or CAPL TestUnit helper.
   */
  switch (level) {
    case 1:
    default:
      for (i = 0; i < 4; i++) {
        key[i] = seed[i] ^ kSecKeyLevel1[i];
      }
      break;
    default:
      TestStepFail("UnlockLevel", "Unknown security level %d", level);
      return 0;
  }

  return Uds_SecurityAccessSendKey(level, key, 4);
}

/*
 * Uds_ReadDid — send ReadDataByIdentifier for a 2-byte DID.
 * didHi, didLo: DID bytes
 * Returns response byte count, or -1 on failure.
 */
int Uds_ReadDid(byte didHi, byte didLo)
{
  byte pdu[3];
  pdu[0] = kSidRDBI;
  pdu[1] = didHi;
  pdu[2] = didLo;
  return UdsRequest(pdu, 3);
}

/*
 * Uds_WriteDid — send WriteDataByIdentifier.
 * data[]: payload bytes, dataLen: byte count
 * Returns response byte count, or -1 on failure.
 */
int Uds_WriteDid(byte didHi, byte didLo, byte data[], dword dataLen)
{
  byte  pdu[4099];
  dword i;
  pdu[0] = kSidWDBI;
  pdu[1] = didHi;
  pdu[2] = didLo;
  for (i = 0; i < dataLen; i++) {
    pdu[3 + i] = data[i];
  }
  return UdsRequest(pdu, 3 + dataLen);
}

/*
 * Uds_ClearDtcs — send ClearDiagnosticInformation (0x14 0xFF 0xFF 0xFF).
 */
int Uds_ClearDtcs()
{
  byte pdu[4];
  pdu[0] = 0x14;
  pdu[1] = 0xFF;
  pdu[2] = 0xFF;
  pdu[3] = 0xFF;
  return UdsRequest(pdu, 4);
}

/*
 * Uds_ReadDtcByStatus — send ReadDTCInformation sub-fn 0x02.
 * statusMask: bitmask (e.g. 0xFF for all DTCs)
 */
int Uds_ReadDtcByStatus(byte statusMask)
{
  byte pdu[3];
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x02;   /* reportDTCByStatusMask */
  pdu[2] = statusMask;
  return UdsRequest(pdu, 3);
}

/*
 * Uds_EcuReset — send ECUReset (0x11).
 * resetType: 0x01=hardReset, 0x03=softReset
 */
int Uds_EcuReset(byte resetType)
{
  byte pdu[2];
  pdu[0] = kSidECUReset;
  pdu[1] = resetType;
  return UdsRequest(pdu, 2);
}

/* ── Pass / Fail helper wrappers ─────────────────────────────────────────── */

void AssertPositiveResponse(int rc, byte expectedSid, char stepName[])
{
  if (rc < 0) {
    TestStepFail(stepName, "No response received (timeout)");
    gTestFailCount++;
    return;
  }
  if (gRxBuf[0] != (byte)(expectedSid + kPosDelta)) {
    if (gRxBuf[0] == kSidNR) {
      TestStepFail(stepName,
        "Expected positive response 0x%02X, got NRC 0x%02X",
        expectedSid + kPosDelta, gRxBuf[2]);
    } else {
      TestStepFail(stepName,
        "Expected SID 0x%02X, got 0x%02X",
        expectedSid + kPosDelta, gRxBuf[0]);
    }
    gTestFailCount++;
    return;
  }
  TestStepPass(stepName, "Positive response 0x%02X received", gRxBuf[0]);
  gTestPassCount++;
}

void AssertNegativeResponse(int rc, byte expectedNrc, char stepName[])
{
  if (rc < 0) {
    TestStepFail(stepName, "No response received (timeout)");
    gTestFailCount++;
    return;
  }
  if (gRxBuf[0] != kSidNR) {
    TestStepFail(stepName,
      "Expected NegativeResponse (0x7F), got SID 0x%02X", gRxBuf[0]);
    gTestFailCount++;
    return;
  }
  if (gRxBuf[2] != expectedNrc) {
    TestStepFail(stepName,
      "Expected NRC 0x%02X, got NRC 0x%02X", expectedNrc, gRxBuf[2]);
    gTestFailCount++;
    return;
  }
  TestStepPass(stepName, "Correct NRC 0x%02X received", expectedNrc);
  gTestPassCount++;
}

void AssertResponseLength(dword actual, dword expected, char stepName[])
{
  if (actual != expected) {
    TestStepFail(stepName,
      "Expected %d bytes, got %d bytes", expected, actual);
    gTestFailCount++;
    return;
  }
  TestStepPass(stepName, "Response length %d bytes correct", actual);
  gTestPassCount++;
}


/* ═══════════════════════════════════════════════════════════════════════════
 *  CORE SERVICE TESTS
 *  0x10, 0x11, 0x27, 0x3E, 0x19
 * ═══════════════════════════════════════════════════════════════════════════ */

testcase TC_Services_DefaultSession()
{
  int rc;
  TestCaseDescription("Verify ECU responds to DiagnosticSessionControl 0x10 0x01");

  rc = Uds_EnterSession(kSessDefault);
  AssertPositiveResponse(rc, kSidDSC, "DSC_DefaultSession_Response");
  /* Echo byte must be 0x01 */
  if (rc > 0 && gRxBuf[1] != kSessDefault) {
    TestStepFail("DSC_DefaultSession_Echo", "Echo byte 0x%02X != 0x01", gRxBuf[1]);
  } else if (rc > 0) {
    TestStepPass("DSC_DefaultSession_Echo", "Session echo byte correct");
  }
}

testcase TC_Services_ExtendedSession()
{
  int rc;
  TestCaseDescription("Verify ECU enters Extended diagnostic session (0x10 0x03)");

  rc = Uds_EnterSession(kSessExtended);
  AssertPositiveResponse(rc, kSidDSC, "DSC_ExtendedSession_Response");
  Uds_EnterSession(kSessDefault);   /* return to default */
}

testcase TC_Services_ProgrammingSession()
{
  int rc;
  TestCaseDescription("Verify ECU enters Programming session (0x10 0x02)");

  rc = Uds_EnterSession(kSessProgramming);
  AssertPositiveResponse(rc, kSidDSC, "DSC_ProgrammingSession_Response");
  Uds_EnterSession(kSessDefault);
}

testcase TC_Services_TesterPresent()
{
  int rc;
  TestCaseDescription("Verify TesterPresent (0x3E 0x00) keeps session alive");

  Uds_EnterSession(kSessDefault);
  rc = (int)(UdsRequest != 0);   /* explicit send */
  {
    byte pdu[2];
    pdu[0] = kSidTesterPresent;
    pdu[1] = 0x00;
    rc = UdsRequest(pdu, 2);
  }
  AssertPositiveResponse(rc, kSidTesterPresent, "TesterPresent_Response");
}

testcase TC_Services_TesterPresentSuppressed()
{
  int rc;
  byte pdu[2];
  TestCaseDescription("Verify TesterPresent with suppressPositiveResponseBit (0x3E 0x80) returns nothing");

  Uds_EnterSession(kSessDefault);
  pdu[0] = kSidTesterPresent;
  pdu[1] = 0x80;   /* suppressPositiveResponseBit set */
  IsoTp_Send(pdu, 2);
  /* Expect silence — wait P2server_max + margin */
  if (testWaitForEvent("eds_isotp_rx_complete", kP2ServerMax + 50) != 0) {
    TestStepFail("TesterPresent_Suppress", "ECU responded but should be silent");
  } else {
    TestStepPass("TesterPresent_Suppress", "Correctly suppressed positive response");
  }
}

testcase TC_Services_EcuReset_Hard()
{
  int rc;
  TestCaseDescription("Verify ECUReset hardReset (0x11 0x01) — positive response then ECU resets");

  Uds_EnterSession(kSessExtended);
  rc = Uds_EcuReset(0x01);
  AssertPositiveResponse(rc, kSidECUReset, "ECUReset_Hard_Response");
  testWaitForDelay(500);   /* allow ECU restart time */
}

testcase TC_Services_EcuReset_Soft()
{
  int rc;
  TestCaseDescription("Verify ECUReset softReset (0x11 0x03)");

  Uds_EnterSession(kSessExtended);
  rc = Uds_EcuReset(0x03);
  AssertPositiveResponse(rc, kSidECUReset, "ECUReset_Soft_Response");
  testWaitForDelay(200);
}

testcase TC_Services_SessionTimeout()
{
  int rc;
  TestCaseDescription(
    "Verify ECU reverts to default session after S3server timeout of 5000 ms");

  /* Enter extended session, then go silent */
  Uds_EnterSession(kSessExtended);
  testWaitForDelay(kS3ServerTimeout + 500);

  /* Now try a DID that requires extended session — should get NRC 0x7F */
  {
    int rd_rc;
    rd_rc = Uds_ReadDid(0xF1, 0x87);
    AssertNegativeResponse(rd_rc, kNrcSvcNotSuppInSess, "SessionTimeout_ExtDIDBlocked");
  }
}


testcase TC_Services_RDTCI_ReportAll()
{
  int rc;
  TestCaseDescription("Verify ReadDTCInformation (0x19 0x02 0xFF) returns valid response");

  Uds_EnterSession(kSessDefault);
  rc = Uds_ReadDtcByStatus(0xFF);
  AssertPositiveResponse(rc, kSidRDTCI, "RDTCI_0x02_Response");
}

testcase TC_Services_ClearDtcs()
{
  int rc;
  TestCaseDescription("Verify ClearDiagnosticInformation (0x14) in extended session");

  Uds_EnterSession(kSessExtended);
  rc = Uds_ClearDtcs();
  AssertPositiveResponse(rc, 0x54, "ClearDTC_Response");
  Uds_EnterSession(kSessDefault);
}


