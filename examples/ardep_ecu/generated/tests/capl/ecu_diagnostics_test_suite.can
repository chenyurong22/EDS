  char  stepName[64];
  TestCaseDescription("Smoke: ReadDataByIdentifier 0x2501 (FirmwareVersion_Active) — happy path");

  Uds_EnterSession(kSessDefault);

  rc = Uds_ReadDid(0x25, 0x01);

  snprintf(stepName, elcount(stepName), "RDBI_0x2501_PositiveResponse");
  AssertPositiveResponse(rc, kSidRDBI, stepName);

  /* Response: 0x62 DID_HI DID_LO + 4 data bytes = 7 total */
  snprintf(stepName, elcount(stepName), "RDBI_0x2501_ResponseLength");
  AssertResponseLength(gRxLen, 7, stepName);

  Uds_EnterSession(kSessDefault);
}
testcase TC_DID_Read_Smoke_2502()
{
  int   rc;
  char  stepName[64];
  TestCaseDescription("Smoke: ReadDataByIdentifier 0x2502 (FirmwareVersion_Pending) — happy path");

  Uds_EnterSession(kSessDefault);

  rc = Uds_ReadDid(0x25, 0x02);

  snprintf(stepName, elcount(stepName), "RDBI_0x2502_PositiveResponse");
  AssertPositiveResponse(rc, kSidRDBI, stepName);

  /* Response: 0x62 DID_HI DID_LO + 4 data bytes = 7 total */
  snprintf(stepName, elcount(stepName), "RDBI_0x2502_ResponseLength");
  AssertResponseLength(gRxLen, 7, stepName);

  Uds_EnterSession(kSessDefault);
}
testcase TC_DID_Read_Smoke_2503()
{
  int   rc;
  char  stepName[64];
  TestCaseDescription("Smoke: ReadDataByIdentifier 0x2503 (FirmwareUpdateStatus) — happy path");

  Uds_EnterSession(kSessDefault);

  rc = Uds_ReadDid(0x25, 0x03);

  snprintf(stepName, elcount(stepName), "RDBI_0x2503_PositiveResponse");
  AssertPositiveResponse(rc, kSidRDBI, stepName);

  /* Response: 0x62 DID_HI DID_LO + 1 data bytes = 4 total */
  snprintf(stepName, elcount(stepName), "RDBI_0x2503_ResponseLength");
  AssertResponseLength(gRxLen, 4, stepName);

  Uds_EnterSession(kSessDefault);
}


