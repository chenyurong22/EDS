/*
 * TC_2401_Read_HappyPath
 * Verify positive ReadDataByIdentifier response for DID 0x2401.
 */
testcase TC_2401_Read_HappyPath()
{
  int rc;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — ReadDataByIdentifier happy path");

  if (!SetupRead_2401()) {
    TestCaseFail("Precondition setup failed");
    return;
  }

  rc = Uds_ReadDid(kDid_2401_Hi,
                   kDid_2401_Lo);

  AssertPositiveResponse(rc, kSidRDBI, "RDBI_0x2401_PositiveResponse");
  Uds_EnterSession(kSessDefault);
}

/*
 * TC_2401_Read_ResponseEcho
 * Verify response echoes DID bytes 0x24, 0x01.
 */
testcase TC_2401_Read_ResponseEcho()
{
  int rc;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — response echoes DID bytes at positions [1],[2]");

  if (!SetupRead_2401()) {
    TestCaseFail("Precondition setup failed");
    return;
  }

  rc = Uds_ReadDid(kDid_2401_Hi,
                   kDid_2401_Lo);

  if (rc < 3) {
    TestStepFail("RDBI_0x2401_Echo", "Response too short: %d bytes", rc);
    gTestFailCount++;
  } else if (gRxBuf[1] != kDid_2401_Hi ||
             gRxBuf[2] != kDid_2401_Lo) {
    TestStepFail("RDBI_0x2401_Echo",
      "DID echo mismatch: got 0x%02X%02X, expected 0x2401",
      gRxBuf[1], gRxBuf[2]);
    gTestFailCount++;
  } else {
    TestStepPass("RDBI_0x2401_Echo",
      "DID echo correct: 0x%02X%02X", gRxBuf[1], gRxBuf[2]);
    gTestPassCount++;
  }
  Uds_EnterSession(kSessDefault);
}

/*
 * TC_2401_Read_ResponseLen
 * Verify data payload = 2 bytes (total response = 5 bytes).
 */
testcase TC_2401_Read_ResponseLen()
{
  int rc;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — response data length = 2 bytes");

  if (!SetupRead_2401()) {
    TestCaseFail("Precondition setup failed");
    return;
  }

  rc = Uds_ReadDid(kDid_2401_Hi,
                   kDid_2401_Lo);

  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDBI + kPosDelta)) {
    AssertResponseLength(gRxLen,
      kDid_2401_RespLen,
      "RDBI_0x2401_ResponseLength");
  } else {
    TestStepFail("RDBI_0x2401_ResponseLength",
      "Cannot check length — no positive response");
    gTestFailCount++;
  }
  Uds_EnterSession(kSessDefault);
}

/*
 * TC_2401_Read_WrongSession
 * Verify NRC 0x7F (serviceNotSupportedInActiveSession) when reading from default session.
 * DID 0x2401 requires extended session.
 */
testcase TC_2401_Read_WrongSession()
{
  int rc;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — NRC 0x7F when accessed in default session");

  /* Deliberately stay in default session */
  Uds_EnterSession(kSessDefault);

  rc = Uds_ReadDid(kDid_2401_Hi,
                   kDid_2401_Lo);

  AssertNegativeResponse(rc, kNrcSvcNotSuppInSess,
    "RDBI_0x2401_WrongSession_NRC0x7F");
}


/*
 * TC_2401_Read_MultipleTimes
 * Verify DID 0x2401 responds consistently across 5 consecutive reads.
 * Detects: race conditions, buffer reuse bugs, handler side-effects.
 */
testcase TC_2401_Read_MultipleTimes()
{
  int   rc;
  int   i;
  int   failCount;
  dword firstLen;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — 5 consecutive reads, consistent responses");

  if (!SetupRead_2401()) {
    TestCaseFail("Precondition setup failed");
    return;
  }

  failCount = 0;
  firstLen  = 0;

  for (i = 0; i < 5; i++) {
    rc = Uds_ReadDid(kDid_2401_Hi,
                     kDid_2401_Lo);
    if (rc < 0 || gRxBuf[0] != (byte)(kSidRDBI + kPosDelta)) {
      failCount++;
      TestStepFail("RDBI_0x2401_Multi",
        "Read %d of 5 failed: rc=%d NRC=0x%02X", i+1, rc,
        (rc >= 3) ? gRxBuf[2] : 0xFF);
    } else {
      if (i == 0) {
        firstLen = gRxLen;
      } else if (gRxLen != firstLen) {
        failCount++;
        TestStepFail("RDBI_0x2401_Multi",
          "Read %d length %d != first read length %d", i+1, gRxLen, firstLen);
      }
    }
    testWaitForDelay(5);   /* 5 ms gap between consecutive requests */
  }

  if (failCount == 0) {
    TestStepPass("RDBI_0x2401_Multi",
      "All 5 reads successful, consistent length %d bytes", firstLen);
    gTestPassCount++;
  } else {
    gTestFailCount++;
  }
  Uds_EnterSession(kSessDefault);
}
  /* access_read */


