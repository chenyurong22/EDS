/*
 * TC_2401_Write_HappyPath
 * Verify positive WriteDataByIdentifier response for DID 0x2401.
 * Writes 2 bytes of 0xAA pattern.
 */
testcase TC_2401_Write_HappyPath()
{
  int   rc;
  byte  data[2];
  dword i;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — WriteDataByIdentifier happy path (2 bytes)");

  if (!SetupWrite_2401()) {
    TestCaseFail("Write precondition setup failed");
    return;
  }

  /* Fill with 0xAA test pattern */
  for (i = 0; i < 2; i++) {
    data[i] = 0xAA;
  }

  rc = Uds_WriteDid(kDid_2401_Hi,
                    kDid_2401_Lo,
                    data, 2);

  AssertPositiveResponse(rc, kSidWDBI, "WDBI_0x2401_PositiveResponse");

  /* Readback verification: read the DID we just wrote */
  if (!SetupRead_2401()) return;
  rc = Uds_ReadDid(kDid_2401_Hi,
                   kDid_2401_Lo);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDBI + kPosDelta)) {
    TestStepPass("WDBI_0x2401_Readback", "DID readable after write");
    gTestPassCount++;
  } else {
    TestStepFail("WDBI_0x2401_Readback", "DID not readable after write");
    gTestFailCount++;
  }
  Uds_EnterSession(kSessDefault);
}

/*
 * TC_2401_Write_WrongLength
 * Verify NRC 0x13 (incorrectMessageLengthOrInvalidFormat) when wrong data length.
 * Sends 1 bytes instead of 2.
 */
testcase TC_2401_Write_WrongLength()
{
  int  rc;
  byte shortData[1];
  dword i;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — NRC 0x13 for wrong data length");

  if (!SetupWrite_2401()) {
    TestCaseFail("Write precondition setup failed");
    return;
  }

  /* Send 1 byte(s) instead of 2 */
  for (i = 0; i < 1; i++) {
    shortData[i] = 0x00;
  }
  rc = Uds_WriteDid(kDid_2401_Hi,
                    kDid_2401_Lo,
                    shortData, 1);

  AssertNegativeResponse(rc, kNrcIncorrectMsgLen,
    "WDBI_0x2401_WrongLength_NRC0x13");
  Uds_EnterSession(kSessDefault);
}

/*
 * TC_2401_Write_WrongSession
 * Verify NRC 0x7F (serviceNotSupportedInActiveSession) when writing from default session.
 */
testcase TC_2401_Write_WrongSession()
{
  int   rc;
  byte  data[2];
  dword i;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — NRC 0x7F on write in default session");

  Uds_EnterSession(kSessDefault);

  for (i = 0; i < 2; i++) {
    data[i] = 0x00;
  }
  rc = Uds_WriteDid(kDid_2401_Hi,
                    kDid_2401_Lo,
                    data, 2);

  AssertNegativeResponse(rc, kNrcSvcNotSuppInSess,
    "WDBI_0x2401_WrongSession_NRC0x7F");
}

/*
 * TC_2401_Write_SecurityLocked
 * Verify NRC 0x33 (securityAccessDenied) when attempting write without security unlock.
 */
testcase TC_2401_Write_SecurityLocked()
{
  int   rc;
  byte  data[2];
  dword i;
  TestCaseDescription(
    "DID 0x2401 (CAN_BusBitrate_kbps) — NRC 0x33 on write when security locked");

  /* Enter session but do NOT unlock */
  Uds_EnterSession(kSessExtended);

  for (i = 0; i < 2; i++) {
    data[i] = 0x00;
  }
  rc = Uds_WriteDid(kDid_2401_Hi,
                    kDid_2401_Lo,
                    data, 2);

  AssertNegativeResponse(rc, kNrcSecAccessDenied,
    "WDBI_0x2401_SecurityLocked_NRC0x33");
  Uds_EnterSession(kSessDefault);
}
  /* access_write */


