/* ── DID constants ───────────────────────────────────────────────────────── */
variables
{
  const word  kDid_2401            = 9217;
  const byte  kDid_2401_Hi        = 0x24;
  const byte  kDid_2401_Lo        = 0x01;
  const dword kDid_2401_DataLen   = 2;
  const int   kDid_2401_RespLen   = 5;  /* 0x62 + DID_HI + DID_LO + data */
  const int   kDid_2401_MinSess   = 3;
  const int   kDid_2401_RSec      = 0;
  const int   kDid_2401_WSec      = 1;
}

/* ── Precondition helper for this DID ────────────────────────────────────── */

/*
 * SetupRead_2401 — enter required session and security level for a read.
 * Returns 1 on success, 0 if setup failed.
 */
int SetupRead_2401()
{
  if (!Uds_EnterSession(kSessExtended))    return 0;
  return 1;
}

/*
 * SetupWrite_2401 — enter required session and security level for a write.
 */
int SetupWrite_2401()
{
  if (!Uds_EnterSession(kSessExtended))    return 0;
  if (!Uds_UnlockLevel(1)) return 0;
  return 1;
}


/* ═══════════════════════════════════════════════════════════════════════════
 *  READ TEST CASES
