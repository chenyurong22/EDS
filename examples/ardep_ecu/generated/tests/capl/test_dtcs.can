  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FF00",
      "DTC 0xC0FF00 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FF00",
        "DTC 0xC0FF00 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FF00",
        "DTC 0xC0FF00 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FF10: Supply voltage high — above 16.0V for > 100ms */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFF);
  pdu[4] = (byte)(0x10);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FF10",
      "DTC 0xC0FF10 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FF10",
        "DTC 0xC0FF10 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FF10",
        "DTC 0xC0FF10 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FF20: ECU overtemperature — internal junction > 125°C */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFF);
  pdu[4] = (byte)(0x20);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FF20",
      "DTC 0xC0FF20 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FF20",
        "DTC 0xC0FF20 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FF20",
        "DTC 0xC0FF20 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FF30: Watchdog reset event — firmware failed to service watchdog */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFF);
  pdu[4] = (byte)(0x30);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FF30",
      "DTC 0xC0FF30 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FF30",
        "DTC 0xC0FF30 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FF30",
        "DTC 0xC0FF30 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FF40: NVM write failure — diagnostic session statistics not persisted */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFF);
  pdu[4] = (byte)(0x40);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FF40",
      "DTC 0xC0FF40 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FF40",
        "DTC 0xC0FF40 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FF40",
        "DTC 0xC0FF40 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FE00: Firmware image verification failed — CRC mismatch */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFE);
  pdu[4] = (byte)(0x00);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FE00",
      "DTC 0xC0FE00 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FE00",
        "DTC 0xC0FE00 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FE00",
        "DTC 0xC0FE00 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

  /* DTC 0xC0FE10: Firmware download incomplete — transfer interrupted */
  pdu[0] = kSidRDTCI;
  pdu[1] = 0x06;   /* reportDTCExtDataRecordByDTCNumber */
  pdu[2] = (byte)(0xC0);
  pdu[3] = (byte)(0xFE);
  pdu[4] = (byte)(0x10);
  pdu[5] = 0xFF;   /* all extended data records */
  rc = UdsRequest(pdu, 6);
  if (rc > 0 && gRxBuf[0] == (byte)(kSidRDTCI + kPosDelta)) {
    TestStepPass("RDTCI_0x06_C0FE10",
      "DTC 0xC0FE10 ext data response: %d bytes", gRxLen);
    gTestPassCount++;
  } else {
    /* NRC 0x31 is acceptable if DTC has no extended data record */
    if (gLastNrc == kNrcReqOutOfRange) {
      TestStepPass("RDTCI_0x06_C0FE10",
        "DTC 0xC0FE10 NRC 0x31 — no ext data (acceptable)");
      gTestPassCount++;
    } else {
      TestStepFail("RDTCI_0x06_C0FE10",
        "DTC 0xC0FE10 unexpected NRC 0x%02X", gLastNrc);
      gTestFailCount++;
    }
  }

}

/*
 * TC_DTC_RDTCI_InvalidSubFunction
 * Verify NRC 0x12 (subFunctionNotSupported) for an invalid sub-function.
 */
testcase TC_DTC_RDTCI_InvalidSubFunction()
{
  byte pdu[2];
  int  rc;
  TestCaseDescription("0x19 0xEE — invalid sub-function returns NRC 0x12");

  pdu[0] = kSidRDTCI;
  pdu[1] = 0xEE;   /* invalid sub-function */
  Uds_EnterSession(kSessDefault);
  rc = UdsRequest(pdu, 2);
  AssertNegativeResponse(rc, 0x12, "RDTCI_InvalidSubFn_NRC0x12");
}

/*
 * TC_DTC_RDTCI_ReportNumberOfDTC
 * Verify ReadDTCInformation sub-fn 0x01 (reportNumberOfDTCByStatusMask).
 */
testcase TC_DTC_RDTCI_ReportNumberOfDTC()
{
  byte pdu[3];
  int  rc;
  TestCaseDescription("0x19 0x01 0xFF — reportNumberOfDTCByStatusMask");

  pdu[0] = kSidRDTCI;
  pdu[1] = 0x01;
  pdu[2] = 0xFF;
  Uds_EnterSession(kSessDefault);
  rc = UdsRequest(pdu, 3);
  AssertPositiveResponse(rc, kSidRDTCI, "RDTCI_0x01_Response");

  /* Response: 0x59 0x01 <statusAvail> <dtcFormatId> <countHi> <countLo> = 6 bytes */
  if (gRxLen >= 6) {
    dword count;
    count = ((dword)gRxBuf[4] << 8) | (dword)gRxBuf[5];
    TestStepPass("RDTCI_0x01_Count", "DTC count field: %d DTCs", count);
    gTestPassCount++;
  } else {
    TestStepFail("RDTCI_0x01_Structure", "Response too short: %d bytes", gRxLen);
    gTestFailCount++;
  }
}


/* ═══════════════════════════════════════════════════════════════════════════
 *  DTC TEST GROUP
 * ═══════════════════════════════════════════════════════════════════════════ */

testgroup TG_DTCTests()
{
  TestGroupDescription("DTC Tests — 19 registered DTCs, services 0x14 / 0x19");

  TC_DTC_ClearAll_Extended();
  TC_DTC_ClearAll_DefaultSession_Denied();
  TC_DTC_RDTCI_ReportByStatusMask_FF();
  TC_DTC_RDTCI_ReportSupportedDTC();
  TC_DTC_RDTCI_ExtendedData_AllDTCs();
  TC_DTC_RDTCI_InvalidSubFunction();
  TC_DTC_RDTCI_ReportNumberOfDTC();
}
