/* ── DTC reporting helpers ─────────────────────────────────────────────── */

/*
 * Dtc_IsPresentInResponse — search for a 3-byte DTC code in gRxBuf.
 * Response format for 0x19 0x02: 0x59 0x02 <statusAvail> [dtc3bytes status]...
 * Returns 1 if found, 0 if not.
 */
int Dtc_IsPresentInResponse(dword dtcCode)
{
  dword i;
  byte  hi, mid, lo;

  if (gRxLen < 3) return 0;

  hi  = (byte)((dtcCode >> 16) & 0xFF);
  mid = (byte)((dtcCode >>  8) & 0xFF);
  lo  = (byte)( dtcCode        & 0xFF);

  /* Skip 0x59 0x02 <statusAvail>, entries start at byte 3, stride = 4 */
  for (i = 3; i + 3 < gRxLen; i += 4) {
    if (gRxBuf[i] == hi && gRxBuf[i+1] == mid && gRxBuf[i+2] == lo) {
      return 1;
    }
  }
  return 0;
}

/*
 * Dtc_GetStatusByte — return status byte for a DTC code in response.
 * Returns status byte, or 0xFF if DTC not found.
 */
byte Dtc_GetStatusByte(dword dtcCode)
{
  dword i;
  byte  hi, mid, lo;

  if (gRxLen < 3) return 0xFF;

  hi  = (byte)((dtcCode >> 16) & 0xFF);
  mid = (byte)((dtcCode >>  8) & 0xFF);
  lo  = (byte)( dtcCode        & 0xFF);

  for (i = 3; i + 3 < gRxLen; i += 4) {
    if (gRxBuf[i] == hi && gRxBuf[i+1] == mid && gRxBuf[i+2] == lo) {
      return gRxBuf[i + 3];
    }
  }
  return 0xFF;
}

/*
 * Dtc_CountInResponse — return the number of DTC entries in a 0x59 0x02 response.
 */
int Dtc_CountInResponse()
{
  if (gRxLen < 3) return 0;
  return (int)((gRxLen - 3) / 4);
}


