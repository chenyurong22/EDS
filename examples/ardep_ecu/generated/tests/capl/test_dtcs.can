/*
 * TC_DTC_ClearAll_Extended
 * Verify ClearDiagnosticInformation (0x14 FF FF FF) in extended session.
 * Post-condition: no DTCs present.
 */
testcase TC_DTC_ClearAll_Extended()
{
  int rc;
  int dtcCount;
  TestCaseDescription("ClearDiagnosticInformation (0x14) — clear all DTCs, verify clean slate");

  Uds_EnterSession(kSessExtended);
  rc = Uds_ClearDtcs();
  AssertPositiveResponse(rc, 0x54, "ClearDTC_PositiveResponse");

  /* Verify no DTCs remain */
  Uds_EnterSession(kSessDefault);
  rc = Uds_ReadDtcByStatus(kDtcStatusMaskAll);
  AssertPositiveResponse(rc, kSidRDTCI, "ClearDTC_VerifyEmpty_Response");

  dtcCount = Dtc_CountInResponse();
  if (dtcCount == 0) {
    TestStepPass("ClearDTC_VerifyEmpty", "Zero DTCs after clear (correct)");
    gTestPassCount++;
  } else {
    TestStepFail("ClearDTC_VerifyEmpty",
      "%d DTC(s) still present after clear", dtcCount);
    gTestFailCount++;
  }
}

/*
 * TC_DTC_ClearAll_DefaultSession_Denied
 * Verify ClearDiagnosticInformation in default session returns NRC 0x7F.
 * ISO 14229 requires extended or programming session for 0x14.
 */
testcase TC_DTC_ClearAll_DefaultSession_Denied()
{
  int rc;
  TestCaseDescription("0x14 ClearDTC in default session — expect NRC 0x7F");

  Uds_EnterSession(kSessDefault);
  rc = Uds_ClearDtcs();
  AssertNegativeResponse(rc, kNrcSvcNotSuppInSess, "ClearDTC_DefaultSess_NRC0x7F");
}

/*
 * TC_DTC_RDTCI_ReportByStatusMask_FF
 * Verify ReadDTCInformation sub-fn 0x02 statusMask=0xFF.
 * Response must be positive; statusAvailabilityMask in byte 2.
 */
testcase TC_DTC_RDTCI_ReportByStatusMask_FF()
{
  int rc;
  TestCaseDescription("0x19 0x02 0xFF — ReadDTCInformation by status mask, all");

  Uds_EnterSession(kSessDefault);
  rc = Uds_ReadDtcByStatus(kDtcStatusMaskAll);
  AssertPositiveResponse(rc, kSidRDTCI, "RDTCI_0x02_0xFF_Response");

  /* Minimum valid response: 0x59 0x02 <statusAvailMask> = 3 bytes */
  if (gRxLen >= 3) {
    TestStepPass("RDTCI_0x02_0xFF_Structure",
      "Response structure valid: SID=0x%02X sub=0x%02X statusAvail=0x%02X",
      gRxBuf[0], gRxBuf[1], gRxBuf[2]);
    gTestPassCount++;
  } else {
    TestStepFail("RDTCI_0x02_0xFF_Structure",
      "Response too short: %d bytes", gRxLen);
    gTestFailCount++;
  }
}

/*
 * TC_DTC_RDTCI_ReportSupportedDTC
 * Verify ReadDTCInformation sub-fn 0x0A (reportSupportedDTCs).
 * Response must list all 19 registered DTCs.
 */
testcase TC_DTC_RDTCI_ReportSupportedDTC()
{
  byte  pdu[2];
  int   rc;
  int   expectedCount;
  int   actualCount;
  TestCaseDescription("0x19 0x0A — reportSupportedDTCs, expect 19 DTCs");

  pdu[0] = kSidRDTCI;
  pdu[1] = 0x0A;   /* reportSupportedDTCs */
  Uds_EnterSession(kSessDefault);
  rc = UdsRequest(pdu, 2);
  AssertPositiveResponse(rc, kSidRDTCI, "RDTCI_0x0A_Response");

  expectedCount = 19;
  actualCount   = Dtc_CountInResponse();

  if (actualCount >= expectedCount) {
    TestStepPass("RDTCI_0x0A_Count",
      "Supported DTC count %d >= expected %d", actualCount, expectedCount);
    gTestPassCount++;
  } else {
    TestStepFail("RDTCI_0x0A_Count",
      "Supported DTC count %d < expected %d", actualCount, expectedCount);
    gTestFailCount++;
  }
}

